# Конфигурация приватного AI-сервиса. Скопировать в .env и заполнить.
# .env в .gitignore — секреты не коммитим.

# Модель (должна быть скачана в Ollama: ollama pull <MODEL>)
MODEL=qwen2.5:1.5b

# API-ключи через запятую. ОБЯЗАТЕЛЬНО задать на проде (иначе auth выключен).
# Сгенерировать: openssl rand -hex 24
API_KEYS=change-me-key-1,change-me-key-2

# Rate limit: запросов за окно (на ключ/IP)
RATE_LIMIT=30
RATE_WINDOW=60

# Ограничения контекста
MAX_INPUT_CHARS=8000
MAX_HISTORY=20
NUM_CTX=4096
NUM_PREDICT=512

# Адрес Ollama (в docker-compose — http://ollama:11434)
OLLAMA_URL=http://localhost:11434

PORT=5008
