# systemd-юнит для запуска API-сервиса без Docker (альтернатива docker-compose).
# Предполагает, что Ollama уже установлен и запущен как сервис (ollama serve),
# а код лежит в /opt/llm-service со своим venv.
#
# Установка:
#   sudo cp deploy/llm-service.service /etc/systemd/system/
#   sudo systemctl daemon-reload && sudo systemctl enable --now llm-service

[Unit]
Description=Private AI service (local LLM via Ollama)
After=network.target ollama.service
Wants=ollama.service

[Service]
Type=simple
User=llm
WorkingDirectory=/opt/llm-service
EnvironmentFile=/opt/llm-service/.env
ExecStart=/opt/llm-service/venv/bin/gunicorn \
    --bind 0.0.0.0:5008 \
    --workers 2 --threads 8 --worker-class gthread \
    --timeout 300 service:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
